{
  "name": "deodar-wears",
  "version": "0.0.0",
  "private": true,
  "description": "Production engineering foundation for Deodar Wears.",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": "24.16.0",
    "pnpm": "11.7.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "pnpm prisma:generate",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts src/test/unit",
    "test:integration": "vitest run --config vitest.integration.config.ts src/test/integration",
    "test:e2e": "playwright test --project=chromium",
    "test:accessibility": "playwright test --project=accessibility",
    "test:security": "vitest run --config vitest.config.ts src/test/security",
    "test:migrations": "tsx scripts/verify-migrations.ts",
    "prisma:generate": "prisma generate",
    "prisma:validate": "prisma validate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed/index.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "audit:dependencies": "pnpm audit --audit-level moderate"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.19",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/nextjs": "10.58.0",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "better-auth": "1.6.19",
    "dotenv": "17.4.2",
    "inngest": "4.6.0",
    "next": "16.2.9",
    "otplib": "13.4.1",
    "pg": "8.22.0",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.61.0",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "axe-core": "4.12.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "29.1.1",
    "playwright": "1.61.0",
    "prettier": "3.8.4",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed/index.ts"
  }
}
