# Required runtime mode. One of: local, test, preview, staging, production.
APP_ENV=local

# Canonical base URL for absolute links and provider callbacks.
APP_URL=http://localhost:3000

# PostgreSQL pooled runtime connection and direct migration connection.
DATABASE_URL=postgresql://deodar:deodar@localhost:5432/deodar_wears
DIRECT_URL=postgresql://deodar:deodar@localhost:5432/deodar_wears

# Isolated PostgreSQL database for integration, migration, and seed proof.
# Never point this at production data.
TEST_DATABASE_URL=postgresql://deodar:deodar@localhost:5432/deodar_wears_test
TEST_DIRECT_URL=postgresql://deodar:deodar@localhost:5432/deodar_wears_test
REQUIRE_DATABASE_TESTS=false

# Optional observability and workflow configuration.
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional production rate-limit provider configuration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Future provider credentials. Do not require or populate until the adapter is enabled.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
RESEND_API_KEY=
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
